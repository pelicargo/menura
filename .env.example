# Slack OAuth token. Can be obtained in the App Settings menu. Required permissions: chat:write, chat:write.customize
SLACK_BOT_TOKEN="xoxb-...."
# Can be obtained by copying a link to the channel - it's the last value and starts with a "C"
SLACK_CHANNEL_ID="Cxxxxxxxxxxx"
# Port to listen on
PORT="3000"
# Twilio authentication, can be obtained from the Twilio dashboard
TWILIO_SID="AC[...]"
TWILIO_TOKEN="[...]"
# URL to fetch hold music from
HOLD_MUSIC="http://api.twilio.com/cowbell.mp3"
# Will be determined automatically if not set
ROOT_URL=""
# Generate via "pnpm pwgen"
ADMIN_PASS=""
# Comma separated values. Don't exceed more than 9. 
TEAMS="Sales,Customer Service"
# Should be self explanitory. Used for IVR
COMPANY_NAME="ACME Company Inc"
