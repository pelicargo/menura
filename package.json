{
  "name": "twilio-groupline",
  "version": "0.0.1",
  "type": "module",
  "description": "Twilio Group call server",
  "main": "src/app.ts",
  "scripts": {
    "start": "node --env-file .env ./dist/app.js",
    "dev": "tsx --watch ./src/app.ts --env-file .env",
    "dev:debug": "pnpm dev --inspect",
    "build": "tsc -p tsconfig.json",
    "lint": "pnpm exec biome check .",
    "format": "pnpm exec biome check --write .",
    "format:ci": "pnpm exec biome ci . --diagnostic-level=error",
    "test": "glob test/**/*.test.ts -c 'tsx --test'",
    "test:debug": "pnpm test -- --inspect-wait",
    "pwgen": "node -e 'let c = require(`crypto`); let [pass, salt] = [c.randomBytes(32).toString(`base64url`), c.randomBytes(16).toString(`hex`)]; console.log(`Password: ${pass}\nHash: ${c.scryptSync(pass, salt, 32).toString(`hex`)}\\$${salt}`)'"
  },
  "author": "Pelicargo Inc and contributors",
  "license": "MIT",
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@slack/web-api": "7.15.1",
    "axios": "1.15.0",
    "body-parser": "2.2.2",
    "date-fns": "4.1.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "twilio": "5.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/body-parser": "1.19.6",
    "@types/express": "5.0.6",
    "@types/node": "22.13.14",
    "glob": "13.0.6",
    "prettier": "3.8.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
